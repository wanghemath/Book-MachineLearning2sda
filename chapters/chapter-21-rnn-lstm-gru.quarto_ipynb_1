        "        cell = cell.lower()\n",
        "        if cell == \"rnn\":\n",
        "            self.recurrent = nn.RNN(1, hidden_size, batch_first=True)\n",
        "        elif cell == \"lstm\":\n",
        "            self.recurrent = nn.LSTM(1, hidden_size, batch_first=True)\n",
        "        elif cell == \"gru\":\n",
        "            self.recurrent = nn.GRU(1, hidden_size, batch_first=True)\n",
        "        else:\n",
        "            raise ValueError(\"cell must be 'rnn', 'lstm', or 'gru'\")\n",
        "        self.head = nn.Linear(hidden_size, horizon)\n",
        "\n",
        "    def forward(self, x):\n",
        "        out, state = self.recurrent(x)\n",
