        "#| label: ch21-window-dataset\n",
        "#| fig-cap: Synthetic time series used for RNN, LSTM, and GRU examples.\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "rng = np.random.default_rng(21)\n",
        "T = 420\n",
        "t = np.arange(T)\n",
        "\n",
        "signal = (\n",
        "    0.012 * t\n",
        "    + 1.4 * np.sin(2 * np.pi * t / 32)\n",
        "    + 0.6 * np.sin(2 * np.pi * t / 9)\n",
        ")\n",
        "noise = rng.normal(scale=0.35, size=T)\n",
        "y = signal + noise\n",
        "\n",
        "L = 36     # input length\n",
        "H = 6      # forecast horizon\n",
        "\n",
        "X, Y = [], []\n",
        "for start in range(T - L - H + 1):\n",
        "    X.append(y[start:start + L])\n",
        "    Y.append(y[start + L:start + L + H])\n",
        "\n",
        "X = np.array(X)\n",
        "Y = np.array(Y)\n",
        "\n",
        "print(\"X shape:\", X.shape)  # windows x input length\n",
        "print(\"Y shape:\", Y.shape)  # windows x forecast horizon\n",
        "\n",
        "plt.figure(figsize=(8, 3.5))\n",
        "plt.plot(t, y, label=\"observed\")\n",
        "plt.axvspan(0, 300, alpha=0.15, label=\"training region\")\n",
        "plt.xlabel(\"time\")\n",
        "plt.ylabel(\"value\")\n",
        "plt.title(\"Synthetic sequence for recurrent forecasting\")\n",
        "plt.legend()\n",
        "plt.show()"
      ],
