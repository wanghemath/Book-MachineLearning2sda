        "#| fig-cap: Wavelet thresholding removes small coefficients and reconstructs a denoised signal.\n",
        "#| warning: false\n",
        "\n",
        "\n",
        "def soft_threshold(x, lam):\n",
        "    return np.sign(x) * np.maximum(np.abs(x) - lam, 0.0)\n",
        "\n",
        "coarse, details = haar_transform(noisy)\n",
        "sigma_hat = np.median(np.abs(details[-1])) / 0.6745\n",
        "lam = sigma_hat * np.sqrt(2 * np.log(n))\n",
        "\n",
        "details_soft = [soft_threshold(d, lam) for d in details]\n",
        "denoised = inverse_haar_transform(coarse, details_soft)\n",
        "\n",
