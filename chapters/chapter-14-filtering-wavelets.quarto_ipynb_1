        "#| label: ch14-haar-transform-from-scratch\n",
        "#| fig-cap: A Haar wavelet transform separates a signal into coarse and detail coefficients.\n",
        "#| warning: false\n",
        "\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "\n",
        "def haar_transform(x):\n",
        "    \"\"\"Return the orthonormal Haar wavelet coefficients of a length-2^J vector.\"\"\"\n",
        "    x = np.asarray(x, dtype=float).copy()\n",
        "    n = len(x)\n",
        "    coeffs = []\n",
        "    current = x.copy()\n",
        "    while len(current) > 1:\n",
        "        avg = (current[0::2] + current[1::2]) / np.sqrt(2)\n",
        "        detail = (current[0::2] - current[1::2]) / np.sqrt(2)\n",
        "        coeffs.append(detail)\n",
        "        current = avg\n",
        "    coeffs.append(current)\n",
        "    # Store as [coarsest average, finest-to-coarsest details reversed]\n",
        "    return coeffs[-1], coeffs[-2::-1]\n",
        "\n",
        "\n",
        "def inverse_haar_transform(coarse, details):\n",
        "    \"\"\"Invert coefficients returned by haar_transform.\"\"\"\n",
        "    current = np.asarray(coarse, dtype=float)\n",
        "    for detail in details:\n",
        "        detail = np.asarray(detail, dtype=float)\n",
        "        out = np.empty(current.size * 2)\n",
        "        out[0::2] = (current + detail) / np.sqrt(2)\n",
        "        out[1::2] = (current - detail) / np.sqrt(2)\n",
        "        current = out\n",
        "    return current\n",
        "\n",
        "n = 256\n",
        "t = np.arange(n)\n",
        "clean = np.sin(2 * np.pi * t / 64)\n",
        "clean += 0.7 * ((t >= 110) & (t <= 135))  # local transient\n",
        "noisy = clean + 0.35 * rng.normal(size=n)\n",
        "\n",
        "coarse, details = haar_transform(noisy)\n",
        "reconstructed = inverse_haar_transform(coarse, details)\n",
        "\n",
        "print(\"Maximum reconstruction error:\", np.max(np.abs(noisy - reconstructed)))\n",
        "print(\"Time-domain energy:\", np.sum(noisy ** 2))\n",
        "print(\"Wavelet-domain energy:\", np.sum(coarse ** 2) + sum(np.sum(d ** 2) for d in details))\n",
        "\n",
        "plt.figure(figsize=(10, 4))\n",
        "plt.plot(t, noisy, label=\"noisy signal\", alpha=0.65)\n",
        "plt.plot(t, clean, label=\"clean signal\", linewidth=2)\n",
        "plt.xlabel(\"time\")\n",
        "plt.ylabel(\"value\")\n",
        "plt.title(\"Signal with a local transient\")\n",
        "plt.legend()\n",
        "plt.show()"
      ],
