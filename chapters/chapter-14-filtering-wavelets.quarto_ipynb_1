        "    document.getElementById('ch14-fast-frequency-value').textContent = fast.toFixed(2);\n",
        "    document.getElementById('ch14-noise-level-value').textContent = noise.toFixed(2);\n",
        "\n",
        "    var n = 240;\n",
        "    var t = [];\n",
        "    var x = [];\n",
        "    var slow = [];\n",
        "    for (var i = 0; i < n; i++) {\n",
        "      t.push(i);\n",
        "      var s = 1.4 * Math.sin(2 * Math.PI * 0.025 * i);\n",
        "      slow.push(s);\n",
        "      x.push(s + 0.45 * Math.sin(2 * Math.PI * fast * i) + noise * gaussianNoise(i));\n",
        "    }\n",
        "    var ma = movingAverage(x, m);\n",
        "    var hp = difference(x);\n",
        "\n",
        "    Plotly.newPlot('ch14-filter-time-plot', [\n",
        "      {x: t, y: x, mode: 'lines', name: 'raw series'},\n",
        "      {x: t, y: ma, mode: 'lines', name: 'moving-average low-pass'},\n",
        "      {x: t, y: hp, mode: 'lines', name: 'first difference high-pass'},\n",
        "      {x: t, y: slow, mode: 'lines', name: 'slow component', line: {dash: 'dot'}}\n",
        "    ], {\n",
        "      title: 'Filtering in the time domain',\n",
        "      xaxis: {title: 'time'},\n",
        "      yaxis: {title: 'value'},\n",
        "      margin: {t: 55, r: 20, b: 50, l: 55}\n",
        "    }, {responsive: true});\n",
        "\n",
        "    var w = [];\n",
        "    var maResp = [];\n",
        "    var diffResp = [];\n",
        "    for (var k = 0; k <= 300; k++) {\n",
        "      var ww = 0.5 * k / 300;\n",
        "      w.push(ww);\n",
        "      maResp.push(maResponse(ww, m));\n",
        "      diffResp.push(4 * Math.pow(Math.sin(Math.PI * ww), 2));\n",
        "    }\n",
        "    Plotly.newPlot('ch14-filter-response-plot', [\n",
        "      {x: w, y: maResp, mode: 'lines', name: '|A(ω)|² moving average'},\n",
        "      {x: w, y: diffResp, mode: 'lines', name: '|A(ω)|² first difference'}\n",
        "    ], {\n",
        "      title: 'Magnitude-squared frequency responses',\n",
        "      xaxis: {title: 'frequency ω', range: [0, 0.5]},\n",
        "      yaxis: {title: '|A(ω)|²'},\n",
        "      margin: {t: 55, r: 20, b: 50, l: 55}\n",
        "    }, {responsive: true});\n",
        "  }\n",
        "  ['ch14-ma-window','ch14-fast-frequency','ch14-noise-level'].forEach(function(id){\n",
        "    document.getElementById(id).addEventListener('input', update);\n",
        "  });\n",
        "  update();\n",
        "})();\n",
        "</script>\n",
        ":::\n",
