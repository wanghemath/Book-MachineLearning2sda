        "\n",
        "<script>\n",
        "(function(){\n",
        "  function gaussianNoise(i) {\n",
        "    var u = Math.sin((i + 1) * 12.9898) * 43758.5453;\n",
        "    return (u - Math.floor(u)) * 2 - 1;\n",
        "  }\n",
        "  function movingAverage(x, m) {\n",
        "    var y = [];\n",
        "    for (var i = 0; i < x.length; i++) {\n",
        "      var s = 0;\n",
        "      var c = 0;\n",
        "      for (var j = 0; j < m; j++) {\n",
        "        var idx = i - j;\n",
        "        if (idx >= 0) { s += x[idx]; c += 1; }\n",
        "      }\n",
        "      y.push(s / c);\n",
        "    }\n",
        "    return y;\n",
        "  }\n",
        "  function difference(x) {\n",
        "    var y = [0];\n",
        "    for (var i = 1; i < x.length; i++) y.push(x[i] - x[i - 1]);\n",
        "    return y;\n",
        "  }\n",
        "  function maResponse(w, m) {\n",
        "    var num = Math.sin(Math.PI * m * w);\n",
        "    var den = m * Math.sin(Math.PI * w);\n",
        "    if (Math.abs(den) < 1e-8) return 1;\n",
        "    return Math.pow(num / den, 2);\n",
        "  }\n",
