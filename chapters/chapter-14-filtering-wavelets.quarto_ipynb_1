        "#| label: ch14-frequency-response-python\n",
        "#| fig-cap: Magnitude-squared responses of common filters.\n",
        "#| warning: false\n",
        "\n",
        "omega = np.linspace(0, 0.5, 800)\n",
        "\n",
        "def moving_average_response(omega, m):\n",
        "    # H(omega) = (1/m) sum_{j=0}^{m-1} exp(-2 pi i omega j)\n",
        "    response = np.zeros_like(omega, dtype=complex)\n",
        "    for j in range(m):\n",
        "        response += np.exp(-2j * np.pi * omega * j) / m\n",
        "    return response\n",
        "\n",
        "A_ma = moving_average_response(omega, m=13)\n",
        "A_diff = 1 - np.exp(-2j * np.pi * omega)\n",
        "A_seasonal = 1 - np.exp(-2j * np.pi * 12 * omega)\n",
        "\n",
        "plt.figure(figsize=(9, 4))\n",
        "plt.plot(omega, np.abs(A_ma) ** 2, label=\"MA(13) smoother\")\n",
        "plt.plot(omega, np.abs(A_diff) ** 2, label=\"first difference\")\n",
        "plt.plot(omega, np.abs(A_seasonal) ** 2, label=\"seasonal difference, s=12\")\n",
        "plt.xlabel(\"frequency ω\")\n",
        "plt.ylabel(\"squared gain |A(ω)|²\")\n",
        "plt.title(\"Frequency responses of three filters\")\n",
        "plt.legend()\n",
        "plt.show()"
      ],
