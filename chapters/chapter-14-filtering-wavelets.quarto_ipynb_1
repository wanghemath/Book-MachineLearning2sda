        "#| label: ch14-filtering-example\n",
        "#| fig-cap: A moving-average filter suppresses high-frequency variation, while differencing emphasizes short-scale changes.\n",
        "#| warning: false\n",
        "\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "rng = np.random.default_rng(7339)\n",
        "n = 240\n",
        "t = np.arange(n)\n",
        "slow = 1.4 * np.sin(2 * np.pi * 0.025 * t)\n",
        "fast = 0.45 * np.sin(2 * np.pi * 0.22 * t)\n",
        "noise = 0.35 * rng.normal(size=n)\n",
        "x = slow + fast + noise\n",
        "\n",
        "m = 13\n",
        "kernel = np.ones(m) / m\n",
        "ma = np.convolve(x, kernel, mode=\"same\")\n",
        "diff = np.r_[np.nan, np.diff(x)]\n",
        "\n",
        "plt.figure(figsize=(10, 4))\n",
        "plt.plot(t, x, label=\"raw\", alpha=0.6)\n",
        "plt.plot(t, ma, label=\"centered moving average\")\n",
        "plt.plot(t, slow, label=\"slow component\", linestyle=\"--\")\n",
        "plt.xlabel(\"time\")\n",
        "plt.ylabel(\"value\")\n",
        "plt.title(\"Low-pass smoothing with a moving-average filter\")\n",
        "plt.legend()\n",
        "plt.show()\n",
        "\n",
        "plt.figure(figsize=(10, 3))\n",
        "plt.plot(t, diff, label=\"first difference\")\n",
        "plt.xlabel(\"time\")\n",
        "plt.ylabel(\"difference\")\n",
        "plt.title(\"High-pass behavior of the first-difference filter\")\n",
        "plt.legend()\n",
        "plt.show()"
      ],
