      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: ch12-ar1-spectra\n",
        "#| fig-cap: Theoretical spectral densities for positive and negative AR(1) coefficients.\n",
        "\n",
        "omega_grid = np.linspace(0, 0.5, 400)\n",
        "\n",
        "def ar1_spectrum(phi, sigma2=1.0):\n",
        "    return sigma2 / (1 - 2*phi*np.cos(2*np.pi*omega_grid) + phi**2)\n",
        "\n",
        "plt.figure(figsize=(10, 4))\n",
        "plt.plot(omega_grid, ar1_spectrum(0.9), label=r\"$\\phi=0.9$\")\n",
        "plt.plot(omega_grid, ar1_spectrum(-0.9), label=r\"$\\phi=-0.9$\")\n",
        "plt.xlabel(\"frequency\")\n",
        "plt.ylabel(\"spectral density\")\n",
        "plt.title(\"AR(1) spectra\")\n",
        "plt.legend()\n",
        "plt.show()"
      ],
      "id": "ch12-ar1-spectra",
      "execution_count": null,
      "outputs": []
    },
