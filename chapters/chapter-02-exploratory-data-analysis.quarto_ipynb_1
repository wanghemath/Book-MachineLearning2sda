        "\n",
        "<script>\n",
        "(function(){\n",
        "  function $(id){ return document.getElementById(id); }\n",
        "  function normal(seed){\n",
        "    seed.state = (1664525 * seed.state + 1013904223) >>> 0;\n",
        "    const u1 = Math.max(seed.state / 4294967296, 1e-12);\n",
        "    seed.state = (1664525 * seed.state + 1013904223) >>> 0;\n",
        "    const u2 = Math.max(seed.state / 4294967296, 1e-12);\n",
        "    return Math.sqrt(-2*Math.log(u1))*Math.cos(2*Math.PI*u2);\n",
        "  }\n",
        "  function simulate(n, slope, amp, period, noise){\n",
        "    const seed = {state: 2402};\n",
        "    const y = [];\n",
        "    let ar = 0;\n",
        "    for(let t=0; t<n; t++){\n",
        "      ar = 0.55*ar + normal(seed);\n",
        "      const season = amp*Math.sin(2*Math.PI*t/period) + 0.5*amp*Math.cos(4*Math.PI*t/period);\n",
        "      const value = 4 + slope*t + season + noise*ar;\n",
        "      y.push(value);\n",
        "    }\n",
        "    return y;\n",
        "  }\n",
        "  function movingAverage(y, m){\n",
        "    const out = [];\n",
        "    for(let i=0; i<y.length; i++){\n",
        "      let s = 0, c = 0;\n",
        "      for(let j=Math.max(0, i-m+1); j<=i; j++){ s += y[j]; c++; }\n",
        "      out.push(s/c);\n",
        "    }\n",
        "    return out;\n",
        "  }\n",
        "  function linTrend(y){\n",
        "    const n = y.length;\n",
        "    const tx = (n-1)/2;\n",
        "    const ybar = y.reduce((a,b)=>a+b,0)/n;\n",
        "    let num = 0, den = 0;\n",
        "    for(let t=0; t<n; t++){\n",
        "      num += (t-tx)*(y[t]-ybar);\n",
        "      den += (t-tx)*(t-tx);\n",
        "    }\n",
        "    const b1 = den === 0 ? 0 : num/den;\n",
        "    const b0 = ybar - b1*tx;\n",
        "    return Array.from({length:n}, (_,t)=>b0+b1*t);\n",
        "  }\n",
        "  function diff(y, lag){\n",
        "    const out = [];\n",
        "    for(let t=lag; t<y.length; t++) out.push(y[t]-y[t-lag]);\n",
        "    return out;\n",
        "  }\n",
        "  function acf(y, maxLag){\n",
        "    const n = y.length;\n",
        "    const mu = y.reduce((a,b)=>a+b,0)/n;\n",
        "    const den = y.reduce((a,b)=>a+(b-mu)*(b-mu),0);\n",
        "    const out = [];\n",
        "    for(let h=0; h<=maxLag; h++){\n",
