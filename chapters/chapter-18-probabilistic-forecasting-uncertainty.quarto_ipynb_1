        "#| label: ch18-coverage-width\n",
        "#| fig-cap: Coverage and width can be summarized by forecast horizon.\n",
        "#| warning: false\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "rng = np.random.default_rng(18)\n",
        "origins = np.arange(80)\n",
        "horizons = np.arange(1, 8)\n",
        "rows = []\n",
        "for h in horizons:\n",
        "    for t in origins:\n",
        "        true_mean = 20 + 0.1 * t + 0.4 * h\n",
        "        true_sd = 0.8 + 0.15 * h\n",
        "        y_true = true_mean + rng.normal(0, true_sd)\n",
        "        # Deliberately underestimates uncertainty at long horizons.\n",
        "        model_sd = 0.9 + 0.08 * h\n",
        "        lo = true_mean - 1.64485 * model_sd\n",
        "        hi = true_mean + 1.64485 * model_sd\n",
        "        rows.append((t, h, y_true, lo, hi))\n",
        "\n",
        "bt = pd.DataFrame(rows, columns=[\"origin\", \"horizon\", \"y\", \"lower\", \"upper\"])\n",
        "bt[\"covered\"] = (bt[\"y\"] >= bt[\"lower\"]) & (bt[\"y\"] <= bt[\"upper\"])\n",
        "bt[\"width\"] = bt[\"upper\"] - bt[\"lower\"]\n",
        "summary = bt.groupby(\"horizon\").agg(\n",
        "    coverage=(\"covered\", \"mean\"),\n",
        "    avg_width=(\"width\", \"mean\")\n",
        ").reset_index()\n",
        "\n",
        "print(summary)\n",
        "\n",
        "plt.figure(figsize=(7, 4))\n",
        "plt.plot(summary[\"horizon\"], summary[\"coverage\"], marker=\"o\", label=\"empirical coverage\")\n",
        "plt.axhline(0.90, linestyle=\"--\", label=\"nominal 90%\")\n",
        "plt.xlabel(\"forecast horizon\")\n",
        "plt.ylabel(\"coverage\")\n",
        "plt.ylim(0.4, 1.0)\n",
        "plt.title(\"Interval coverage by horizon\")\n",
        "plt.legend()\n",
        "plt.show()"
