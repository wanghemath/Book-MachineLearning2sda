        "#| label: ch18-ar1-intervals\n",
        "#| fig-cap: AR(1) simulation with model-based multi-step prediction intervals.\n",
        "#| warning: false\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "rng = np.random.default_rng(7339)\n",
        "\n",
        "phi = 0.75\n",
        "sigma_w = 1.0\n",
        "n = 220\n",
        "y = np.zeros(n)\n",
        "for t in range(1, n):\n",
        "    y[t] = phi * y[t-1] + rng.normal(0, sigma_w)\n",
        "\n",
        "origin = 180\n",
        "H = 30\n",
        "last = y[origin]\n",
        "h = np.arange(1, H + 1)\n",
        "mean_fcst = (phi ** h) * last\n",
        "var_fcst = sigma_w**2 * (1 - phi ** (2 * h)) / (1 - phi**2)\n",
        "se_fcst = np.sqrt(var_fcst)\n",
        "z90 = 1.6448536269514722\n",
        "lower = mean_fcst - z90 * se_fcst\n",
        "upper = mean_fcst + z90 * se_fcst\n",
        "\n",
        "future_index = np.arange(origin + 1, origin + H + 1)\n",
        "\n",
        "plt.figure(figsize=(9, 4))\n",
        "plt.plot(np.arange(origin - 80, origin + 1), y[origin-80:origin+1], label=\"observed\")\n",
        "plt.plot(future_index, y[origin+1:origin+H+1], label=\"future observed\")\n",
        "plt.plot(future_index, mean_fcst, label=\"AR(1) mean forecast\")\n",
        "plt.fill_between(future_index, lower, upper, alpha=0.25, label=\"90% interval\")\n",
        "plt.axvline(origin, linestyle=\"--\", linewidth=1)\n",
        "plt.xlabel(\"time\")\n",
        "plt.ylabel(\"value\")\n",
        "plt.title(\"Model-based AR(1) prediction interval\")\n",
        "plt.legend()\n",
        "plt.show()"
      ],
