        "#| label: ch03-python-acf-function\n",
        "#| warning: false\n",
        "import numpy as np\n",
        "import plotly.graph_objects as go\n",
        "\n",
        "\n",
        "def sample_acf(x, max_lag):\n",
        "    \"\"\"Biased sample ACF using denominator n, matching a common time-series convention.\"\"\"\n",
        "    x = np.asarray(x, dtype=float)\n",
        "    n = len(x)\n",
        "    x_centered = x - x.mean()\n",
        "    gamma0 = np.sum(x_centered * x_centered) / n\n",
        "    values = []\n",
        "    for h in range(max_lag + 1):\n",
        "        gamma_h = np.sum(x_centered[h:] * x_centered[: n - h]) / n\n",
        "        values.append(gamma_h / gamma0)\n",
        "    return np.array(values)\n",
        "\n",
        "max_lag = 40\n",
        "acf_white = sample_acf(white_noise, max_lag)\n",
        "acf_rw = sample_acf(random_walk, max_lag)\n",
        "acf_ar1 = sample_acf(ar1, max_lag)\n",
        "acf_ma1 = sample_acf(ma1, max_lag)\n",
        "\n",
        "lags = np.arange(max_lag + 1)\n",
        "ci = 1.96 / np.sqrt(n)\n",
        "\n",
        "fig = go.Figure()\n",
        "for acf_values, name in [\n",
        "    (acf_white, \"white noise\"),\n",
        "    (acf_rw, \"random walk\"),\n",
        "    (acf_ar1, \"AR(1), phi=0.75\"),\n",
        "    (acf_ma1, \"MA(1), theta=0.70\"),\n",
        "]:\n",
        "    fig.add_trace(go.Scatter(x=lags, y=acf_values, mode=\"lines+markers\", name=name))\n",
        "fig.add_hline(y=ci, line_dash=\"dash\")\n",
        "fig.add_hline(y=-ci, line_dash=\"dash\")\n",
        "fig.update_layout(\n",
        "    title=\"Sample ACF comparison\",\n",
        "    xaxis_title=\"lag\",\n",
        "    yaxis_title=\"sample ACF\",\n",
        "    yaxis_range=[-1, 1],\n",
        "    height=500,\n",
        ")\n",
        "fig.show()"
