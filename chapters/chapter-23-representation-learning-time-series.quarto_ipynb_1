      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: ch23-python-masked-reconstruction\n",
        "#| fig-cap: Masked reconstruction as a self-supervised pretext task.\n",
        "rng = np.random.default_rng(31)\n",
        "L = 120\n",
        "t = np.arange(L)\n",
        "x = np.sin(2*np.pi*t/35) + 0.35*np.sin(2*np.pi*t/9) + 0.15*rng.normal(size=L)\n",
        "\n",
        "mask = np.zeros(L, dtype=bool)\n",
        "mask[45:65] = True\n",
        "observed_t = t[~mask]\n",
        "observed_x = x[~mask]\n",
        "\n",
        "# A simple interpolation baseline for the masked block.\n",
        "x_recon = x.copy()\n",
        "x_recon[mask] = np.interp(t[mask], observed_t, observed_x)\n",
        "\n",
        "masked_mse = np.mean((x[mask] - x_recon[mask])**2)\n",
        "print(f\"Masked-block reconstruction MSE: {masked_mse:.4f}\")\n",
        "\n",
        "plt.figure(figsize=(8, 4))\n",
        "plt.plot(t, x, label=\"true sequence\")\n",
        "plt.plot(t, x_recon, label=\"masked reconstruction\")\n",
        "plt.scatter(t[mask], x[mask], label=\"hidden values\")\n",
        "plt.xlabel(\"time\")\n",
        "plt.title(\"Self-supervised masked reconstruction task\")\n",
        "plt.legend()\n",
        "plt.show()"
