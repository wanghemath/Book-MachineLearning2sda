        "## 23.13 Python example: a small neural autoencoder\n",
        "\n",
        "The next example trains a small MLP autoencoder. This is not meant to be a state-of-the-art model. It is a minimal representation-learning template."
      ],
      "id": "8dcd3ea4"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: ch23-python-mlp-autoencoder\n",
        "#| fig-cap: Training loss for a small MLP autoencoder.\n",
        "import torch\n",
        "from torch import nn\n",
        "from torch.utils.data import TensorDataset, DataLoader\n",
        "\n",
        "torch.set_num_threads(1)\n",
        "torch.manual_seed(0)\n",
        "\n",
        "rng = np.random.default_rng(21)\n",
        "L = 80\n",
        "train_windows = np.vstack([\n",
        "    make_window(\"low_frequency\", L=L, rng=rng, noise=0.25)\n",
        "    for _ in range(300)\n",
        "]).astype(\"float32\")\n",
        "\n",
        "tensor = torch.tensor(train_windows)\n",
        "loader = DataLoader(TensorDataset(tensor), batch_size=64, shuffle=True)\n",
        "\n",
        "class Autoencoder(nn.Module):\n",
        "    def __init__(self, L, d):\n",
        "        super().__init__()\n",
        "        self.encoder = nn.Sequential(\n",
        "            nn.Linear(L, 32),\n",
        "            nn.ReLU(),\n",
        "            nn.Linear(32, d)\n",
        "        )\n",
        "        self.decoder = nn.Sequential(\n",
        "            nn.Linear(d, 32),\n",
        "            nn.ReLU(),\n",
        "            nn.Linear(32, L)\n",
        "        )\n",
        "\n",
        "    def forward(self, x):\n",
        "        z = self.encoder(x)\n",
        "        xhat = self.decoder(z)\n",
        "        return xhat, z\n",
        "\n",
        "model = Autoencoder(L=L, d=4)\n",
        "optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)\n",
        "loss_fn = nn.MSELoss()\n",
        "losses = []\n",
        "\n",
        "for epoch in range(60):\n",
        "    total = 0.0\n",
        "    count = 0\n",
        "    for (xb,) in loader:\n",
        "        optimizer.zero_grad()\n",
        "        xhat, _ = model(xb)\n",
        "        loss = loss_fn(xhat, xb)\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "        total += loss.item() * xb.shape[0]\n",
        "        count += xb.shape[0]\n",
        "    losses.append(total / count)\n",
        "\n",
        "plt.figure(figsize=(7, 4))\n",
        "plt.plot(losses)\n",
        "plt.xlabel(\"epoch\")\n",
        "plt.ylabel(\"MSE reconstruction loss\")\n",
        "plt.title(\"Autoencoder training loss\")\n",
        "plt.show()\n",
        "\n",
        "with torch.no_grad():\n",
        "    xhat, z = model(tensor[:5])\n",
        "print(\"Latent representation shape:\", z.shape)"
      ],
