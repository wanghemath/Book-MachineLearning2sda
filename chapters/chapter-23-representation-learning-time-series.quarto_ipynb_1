        "#| label: ch23-python-feature-embedding\n",
        "#| fig-cap: PCA embedding of handcrafted time-series features.\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.decomposition import PCA\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "\n",
        "rng = np.random.default_rng(7)\n",
        "L = 80\n",
        "n_per_class = 70\n",
        "\n",
        "def make_window(kind, L=80, rng=None, noise=0.30):\n",
        "    if rng is None:\n",
        "        rng = np.random.default_rng()\n",
        "    t = np.arange(L)\n",
        "    phase = rng.uniform(0, 2*np.pi)\n",
        "\n",
        "    if kind == \"low_frequency\":\n",
        "        x = np.sin(2*np.pi*t/40 + phase)\n",
        "    elif kind == \"high_frequency\":\n",
        "        x = np.sin(2*np.pi*t/10 + phase)\n",
        "    elif kind == \"trend\":\n",
        "        slope = rng.uniform(0.015, 0.035)\n",
        "        x = slope*t + 0.25*np.sin(2*np.pi*t/25 + phase)\n",
        "    elif kind == \"spike\":\n",
        "        x = 0.6*np.sin(2*np.pi*t/30 + phase)\n",
        "        center = rng.integers(L//4, 3*L//4)\n",
        "        x[center:center+3] += rng.uniform(2.0, 3.5)\n",
        "    else:\n",
        "        raise ValueError(\"unknown kind\")\n",
        "\n",
        "    x = x + noise*rng.normal(size=L)\n",
        "    return (x - x.mean()) / (x.std() + 1e-12)\n",
        "\n",
        "def acf1(x):\n",
        "    x = x - x.mean()\n",
        "    denom = np.dot(x, x)\n",
        "    return np.dot(x[1:], x[:-1]) / denom if denom > 0 else 0.0\n",
        "\n",
        "def spectral_amp(x, period):\n",
        "    t = np.arange(len(x))\n",
        "    c = np.cos(2*np.pi*t/period)\n",
        "    s = np.sin(2*np.pi*t/period)\n",
        "    return np.sqrt(np.dot(x, c)**2 + np.dot(x, s)**2) / len(x)\n",
        "\n",
        "def features(x):\n",
        "    t = np.arange(len(x))\n",
        "    slope = np.polyfit(t, x, 1)[0]\n",
        "    return np.array([\n",
        "        x.mean(),\n",
        "        x.std(),\n",
        "        acf1(x),\n",
        "        slope,\n",
        "        spectral_amp(x, 40),\n",
        "        spectral_amp(x, 10),\n",
        "        np.max(np.abs(np.diff(x)))\n",
        "    ])\n",
        "\n",
        "classes = [\"low_frequency\", \"high_frequency\", \"trend\", \"spike\"]\n",
        "X = []\n",
        "y = []\n",
        "for c in classes:\n",
        "    for _ in range(n_per_class):\n",
        "        w = make_window(c, L=L, rng=rng)\n",
        "        X.append(features(w))\n",
        "        y.append(c)\n",
        "\n",
        "X = np.vstack(X)\n",
        "y = np.array(y)\n",
        "\n",
        "Z = PCA(n_components=2, random_state=0).fit_transform(StandardScaler().fit_transform(X))\n",
        "\n",
        "plt.figure(figsize=(7, 5))\n",
        "for c in classes:\n",
        "    idx = y == c\n",
        "    plt.scatter(Z[idx, 0], Z[idx, 1], label=c, alpha=0.75)\n",
        "plt.xlabel(\"PC 1\")\n",
        "plt.ylabel(\"PC 2\")\n",
        "plt.title(\"Feature-based representation of time-series windows\")\n",
        "plt.legend()\n",
        "plt.show()"
      ],
