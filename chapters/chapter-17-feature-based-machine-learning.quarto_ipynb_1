        "#| label: ch17-lag-feature-function\n",
        "#| fig-cap: First rows of a supervised-learning table with lag, rolling, and Fourier features.\n",
        "def make_lagged_features(df, y_col=\"y\", max_lag=14, rolling_windows=(7, 28), horizon=1):\n",
        "    out = df.copy()\n",
        "    y = out[y_col]\n",
        "\n",
        "    # Lag features available at forecast origin t.\n",
        "    for lag in range(1, max_lag + 1):\n",
        "        out[f\"lag_{lag}\"] = y.shift(lag - 1)\n",
        "\n",
        "    # Rolling features using past and current values only.\n",
        "    for w in rolling_windows:\n",
        "        out[f\"roll_mean_{w}\"] = y.rolling(w, min_periods=w).mean()\n",
        "        out[f\"roll_std_{w}\"] = y.rolling(w, min_periods=w).std()\n",
        "\n",
        "    # Calendar and Fourier features known in advance.\n",
        "    day_index = np.arange(len(out))\n",
        "    out[\"day_of_week\"] = out[\"ds\"].dt.dayofweek\n",
        "    out[\"is_weekend\"] = (out[\"day_of_week\"] >= 5).astype(int)\n",
        "    for k in range(1, 4):\n",
        "        out[f\"sin_week_{k}\"] = np.sin(2 * np.pi * k * day_index / 7)\n",
        "        out[f\"cos_week_{k}\"] = np.cos(2 * np.pi * k * day_index / 7)\n",
        "\n",
        "    # Label: value h steps after the forecast origin.\n",
        "    out[f\"target_h{horizon}\"] = y.shift(-horizon)\n",
        "    out = out.dropna().reset_index(drop=True)\n",
        "    return out\n",
        "\n",
        "supervised = make_lagged_features(series, max_lag=14, rolling_windows=(7, 28), horizon=7)\n",
        "feature_cols = [c for c in supervised.columns if c.startswith((\"lag_\", \"roll_\", \"sin_\", \"cos_\"))] + [\"is_weekend\"]\n",
        "target_col = \"target_h7\"\n",
        "\n",
        "supervised[[\"ds\", \"y\"] + feature_cols[:8] + [target_col]].head()"
      ],
