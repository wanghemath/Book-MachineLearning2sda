        "<script>\n",
        "(function() {\n",
        "  function rng(seed) {\n",
        "    let s = seed % 2147483647;\n",
        "    return function() {\n",
        "      s = s * 16807 % 2147483647;\n",
        "      return (s - 1) / 2147483646;\n",
        "    };\n",
        "  }\n",
        "  function normal(rand) {\n",
        "    const u1 = Math.max(rand(), 1e-12);\n",
        "    const u2 = rand();\n",
        "    return Math.sqrt(-2 * Math.log(u1)) * Math.cos(2 * Math.PI * u2);\n",
        "  }\n",
        "  function rollingMean(y, t, w) {\n",
        "    let total = 0;\n",
        "    let count = 0;\n",
        "    for (let j = 0; j < w; j++) {\n",
        "      const idx = t - j;\n",
        "      if (idx >= 0) {\n",
        "        total += y[idx];\n",
        "        count += 1;\n",
        "      }\n",
        "    }\n",
        "    return total / Math.max(count, 1);\n",
        "  }\n",
        "  function standardizeColumns(matrix) {\n",
        "    const rows = matrix.length;\n",
        "    const cols = matrix[0].length;\n",
        "    const out = Array.from({length: rows}, () => Array(cols).fill(0));\n",
        "    for (let c = 0; c < cols; c++) {\n",
        "      const values = matrix.map(row => row[c]);\n",
        "      const mean = values.reduce((a,b) => a+b, 0) / rows;\n",
        "      const sd = Math.sqrt(values.reduce((a,b) => a + (b-mean)*(b-mean), 0) / Math.max(rows-1, 1)) || 1;\n",
        "      for (let r = 0; r < rows; r++) out[r][c] = (matrix[r][c] - mean) / sd;\n",
        "    }\n",
        "    return out;\n",
        "  }\n",
        "  function compute() {\n",
        "    const p = +document.getElementById('ch17_lags').value;\n",
        "    const w = +document.getElementById('ch17_window').value;\n",
        "    const h = +document.getElementById('ch17_horizon').value;\n",
        "    const origin = +document.getElementById('ch17_origin').value;\n",
        "    document.getElementById('ch17_lags_value').innerText = p;\n",
        "    document.getElementById('ch17_window_value').innerText = w;\n",
        "    document.getElementById('ch17_horizon_value').innerText = h;\n",
        "    document.getElementById('ch17_origin_value').innerText = origin;\n",
        "\n",
        "    const n = 160;\n",
        "    const rand = rng(733917);\n",
        "    const t = Array.from({length:n}, (_,i) => i);\n",
        "    const y = [];\n",
        "    let ar = 0;\n",
        "    for (let i = 0; i < n; i++) {\n",
        "      ar = 0.65 * ar + normal(rand);\n",
        "      y.push(40 + 0.08*i + 6*Math.sin(2*Math.PI*i/7) + 2.5*Math.cos(2*Math.PI*i/30) + 2.2*ar);\n",
        "    }\n",
        "\n",
        "    const lagXs = [];\n",
        "    const lagYs = [];\n",
        "    for (let j = 0; j < p; j++) {\n",
        "      const idx = origin - j;\n",
        "      lagXs.push(idx);\n",
        "      lagYs.push(y[idx]);\n",
        "    }\n",
        "    const targetIndex = origin + h;\n",
        "\n",
        "    const traces1 = [\n",
        "      {x:t, y:y, mode:'lines', name:'series'},\n",
        "      {x:lagXs, y:lagYs, mode:'markers', name:'lag features', marker:{size:11}},\n",
        "      {x:[targetIndex], y:[y[targetIndex]], mode:'markers', name:'target y(t+h)', marker:{size:14, symbol:'star'}},\n",
        "      {x:[origin], y:[y[origin]], mode:'markers', name:'forecast origin', marker:{size:13, symbol:'diamond'}}\n",
        "    ];\n",
        "    const shapes = [\n",
        "      {type:'line', x0:origin, x1:origin, yref:'paper', y0:0, y1:1, line:{width:2, dash:'dot'}},\n",
        "      {type:'line', x0:targetIndex, x1:targetIndex, yref:'paper', y0:0, y1:1, line:{width:2, dash:'dash'}}\n",
        "    ];\n",
        "    Plotly.newPlot('ch17_feature_series_plot', traces1, {\n",
        "      title:'Forecast origin, lag features, and target value',\n",
        "      xaxis:{title:'time index'},\n",
        "      yaxis:{title:'series value'},\n",
        "      shapes: shapes,\n",
        "      margin:{t:55, l:55, r:20, b:45}\n",
        "    }, window.TSInteractives ? window.TSInteractives.plotlyConfig : {responsive:true, displayModeBar:true});\n",
        "\n",
        "    const start = Math.max(p + w - 1, 30);\n",
        "    const rows = [];\n",
        "    const rowLabels = [];\n",
        "    for (let row = 0; row < 24; row++) {\n",
        "      const tt = start + row;\n",
        "      const features = [];\n",
        "      for (let j = 0; j < p; j++) features.push(y[tt - j]);\n",
        "      features.push(rollingMean(y, tt, w));\n",
        "      features.push(Math.sin(2*Math.PI*tt/7));\n",
        "      features.push(Math.cos(2*Math.PI*tt/7));\n",
        "      features.push(y[tt + h]);\n",
        "      rows.push(features);\n",
        "      rowLabels.push('origin ' + tt);\n",
        "    }\n",
        "    const z = standardizeColumns(rows);\n",
        "    const colLabels = [];\n",
        "    for (let j = 1; j <= p; j++) colLabels.push('lag_' + j);\n",
        "    colLabels.push('roll_mean_' + w);\n",
        "    colLabels.push('sin_week');\n",
        "    colLabels.push('cos_week');\n",
        "    colLabels.push('target_h' + h);\n",
        "\n",
        "    Plotly.newPlot('ch17_feature_matrix_plot', [{\n",
        "      z: z,\n",
        "      x: colLabels,\n",
        "      y: rowLabels,\n",
        "      type:'heatmap',\n",
        "      colorbar:{title:'standardized value'}\n",
        "    }], {\n",
        "      title:'Supervised-learning table: features and target',\n",
        "      xaxis:{title:'columns'},\n",
        "      yaxis:{title:'rows'},\n",
        "      margin:{t:55, l:95, r:30, b:95}\n",
        "    }, window.TSInteractives ? window.TSInteractives.plotlyConfig : {responsive:true, displayModeBar:true});\n",
        "\n",
        "    document.getElementById('ch17_feature_explanation').innerHTML =\n",
        "      `<strong>Selected row:</strong> At origin t=${origin}, the model may use ` +\n",
        "      `${p} lag values y_t,...,y_{t-${p-1}}, the past rolling mean of width ${w}, and known seasonal features. ` +\n",
        "      `It predicts y_{t+${h}}, located at time ${targetIndex}. ` +\n",
        "      `No value after origin ${origin} is allowed as a feature.`;\n",
        "  }\n",
        "  ['ch17_lags','ch17_window','ch17_horizon','ch17_origin'].forEach(id => {\n",
        "    document.getElementById(id).addEventListener('input', compute);\n",
        "  });\n",
        "  compute();\n",
        "})();\n",
        "</script>\n",
        "\n",
