        "#| label: ch17-simulate-lagged-data\n",
        "#| fig-cap: Synthetic daily time series used for feature-based forecasting.\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
