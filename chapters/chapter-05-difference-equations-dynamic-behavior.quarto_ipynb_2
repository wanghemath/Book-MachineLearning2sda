        "# Backshift polynomial roots are reciprocals of forward roots.\n",
        "z_roots = 1 / eigvals\n",
        "print(\"Backshift roots:\", z_roots)\n",
        "print(\"Causal AR condition |z| > 1?\", np.all(np.abs(z_roots) > 1))"
