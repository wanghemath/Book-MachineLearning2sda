      "source": [
        "#| label: py-ch07-yule-walker\n",
        "#| fig-cap: ACF and PACF of a simulated AR(2) process.\n",
        "#| warning: false\n",
        "\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "np.random.seed(7339)\n",
        "\n",
        "n = 600\n",
        "burn = 200\n",
        "phi_true = np.array([0.65, -0.30])\n",
        "w = np.random.normal(size=n + burn)\n",
        "x = np.zeros(n + burn)\n",
        "\n",
        "for t in range(2, n + burn):\n",
        "    x[t] = phi_true[0] * x[t-1] + phi_true[1] * x[t-2] + w[t]\n",
        "\n",
        "x = x[burn:]\n",
        "\n",
        "\n",
        "def sample_autocovariance(x, max_lag):\n",
        "    x = np.asarray(x)\n",
        "    x_centered = x - x.mean()\n",
        "    n = len(x)\n",
        "    return np.array([\n",
        "        np.dot(x_centered[h:], x_centered[:n-h]) / n\n",
        "        for h in range(max_lag + 1)\n",
        "    ])\n",
        "\n",
        "\n",
        "def yule_walker_estimate(x, p):\n",
        "    gamma = sample_autocovariance(x, p)\n",
        "    Gamma = np.array([[gamma[abs(i-j)] for j in range(p)] for i in range(p)])\n",
        "    rhs = gamma[1:p+1]\n",
        "    phi_hat = np.linalg.solve(Gamma, rhs)\n",
        "    sigma2_hat = gamma[0] - rhs @ phi_hat\n",
        "    return phi_hat, sigma2_hat\n",
        "\n",
        "phi_hat, sigma2_hat = yule_walker_estimate(x, p=2)\n",
        "print(\"True phi:\", phi_true)\n",
        "print(\"Yule-Walker estimate:\", np.round(phi_hat, 4))\n",
        "print(\"Estimated innovation variance:\", round(sigma2_hat, 4))"
      ],
