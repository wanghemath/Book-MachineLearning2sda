        "\n",
        "freq = np.fft.fftfreq(n, d=1)\n",
        "periodogram = (np.abs(D_fft) ** 2) / n\n",
        "\n",
        "plt.figure(figsize=(9, 4))\n",
        "plt.stem(freq[: n // 2 + 1], periodogram[: n // 2 + 1])\n",
        "plt.xlabel(\"frequency\")\n",
        "plt.ylabel(\"periodogram\")\n",
        "plt.title(\"One-sided periodogram from the FFT\")\n",
