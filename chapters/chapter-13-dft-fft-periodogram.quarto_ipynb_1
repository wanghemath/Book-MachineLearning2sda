        "#| label: ch13-leakage-windowing\n",
        "#| fig-cap: A frequency not aligned with the Fourier grid leaks energy into nearby bins; tapering changes the leakage pattern.\n",
        "#| warning: false\n",
        "\n",
        "n = 128\n",
        "t = np.arange(n)\n",
        "\n",
        "# Not an integer number of cycles over the sample.\n",
        "cycles = 10.5\n",
        "omega0 = cycles / n\n",
        "x = np.cos(2 * np.pi * omega0 * t)\n",
