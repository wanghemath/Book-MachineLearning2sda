        "\n",
        "# A synthetic daily series with a weekly component and a mild trend.\n",
        "x = 0.005 * t + 1.8 * np.cos(2 * np.pi * t / 7 + 0.3) + rng.normal(scale=0.7, size=n)\n",
        "\n",
        "# Remove a linear trend before period search.\n",
        "Z_trend = np.column_stack([np.ones(n), t])\n",
        "trend_hat = Z_trend @ np.linalg.lstsq(Z_trend, x, rcond=None)[0]\n",
        "r = x - trend_hat\n",
        "\n",
        "freq = np.fft.rfftfreq(n, d=1)\n",
        "I = np.abs(np.fft.rfft(r - r.mean())) ** 2 / n\n",
        "peak_idx = 1 + np.argmax(I[1:])\n",
        "omega_hat = freq[peak_idx]\n",
        "period_hat = 1 / omega_hat\n",
        "\n",
        "print(\"periodogram peak frequency:\", round(omega_hat, 4))\n",
        "print(\"periodogram peak period:\", round(period_hat, 2))\n",
        "\n",
        "# Fit trend plus sine/cosine at the detected frequency.\n",
        "Z = np.column_stack([\n",
