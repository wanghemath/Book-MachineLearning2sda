        "#| label: ch13-direct-dft-vs-fft\n",
        "#| fig-cap: Direct DFT and FFT give the same coefficients up to numerical precision.\n",
        "#| warning: false\n",
        "\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "rng = np.random.default_rng(7339)\n",
        "n = 32\n",
        "t = np.arange(n)\n",
        "x = 1.2 * np.cos(2 * np.pi * 4 * t / n) + 0.5 * rng.normal(size=n)\n",
        "x = x - x.mean()\n",
        "\n",
        "# Direct DFT matrix: D_k = sum_t x_t exp(-2 pi i k t / n)\n",
        "k = np.arange(n)\n",
        "W = np.exp(-2j * np.pi * np.outer(k, t) / n)\n",
        "D_direct = W @ x\n",
