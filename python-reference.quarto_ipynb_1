        "## A.12 Window datasets for neural networks\n",
        "\n",
        "For neural networks, a common supervised learning format is\n",
        "\n",
        "$$\n",
        "(x_{t-L+1},\\ldots,x_t) \\mapsto (x_{t+1},\\ldots,x_{t+H}).\n",
        "$$"
      ],
      "id": "e35ad65e"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "def make_windows(y, input_length, horizon):\n",
        "    y = np.asarray(y, dtype=np.float32)\n",
        "    X = []\n",
        "    Y = []\n",
        "    for start in range(0, len(y) - input_length - horizon + 1):\n",
        "        end = start + input_length\n",
        "        X.append(y[start:end])\n",
        "        Y.append(y[end:end + horizon])\n",
        "    return np.array(X), np.array(Y)\n",
        "\n",
        "X_win, Y_win = make_windows(y.values, input_length=24, horizon=12)\n",
        "print(X_win.shape, Y_win.shape)"
      ],
      "id": "da197f99",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "A minimal PyTorch dataset is:"
      ],
      "id": "832954ca"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| eval: false\n",
        "class WindowDataset(Dataset):\n",
        "    def __init__(self, X, Y):\n",
        "        self.X = torch.tensor(X, dtype=torch.float32)\n",
        "        self.Y = torch.tensor(Y, dtype=torch.float32)\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.X)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        return self.X[idx], self.Y[idx]\n",
        "\n",
        "train_ds = WindowDataset(X_win, Y_win)\n",
        "train_loader = DataLoader(train_ds, batch_size=32, shuffle=False)"
      ],
