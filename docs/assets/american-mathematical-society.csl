<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl" class="in-text" version="1.0">
  <info><title>Simple AMS-like</title><id>http://example.com/simple-ams-like</id><updated>2026-01-01T00:00:00+00:00</updated></info>
  <macro name="author"><names variable="author"><name initialize-with="." delimiter=", "/></names></macro>
  <citation collapse="citation-number"><sort><key variable="citation-number"/></sort><layout prefix="[" suffix="]" delimiter=", "><text variable="citation-number"/></layout></citation>
  <bibliography><layout><text variable="citation-number" prefix="[" suffix="] "/><text macro="author" suffix=". "/><text variable="title" quotes="true" suffix=". "/><text variable="container-title" font-style="italic" suffix=". "/><date variable="issued"><date-part name="year"/></date></layout></bibliography>
</style>
